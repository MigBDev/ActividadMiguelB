<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="4"
        android:rowCount="5">

        <Button
            android:id="@+id/buttonCA"
            android:layout_width="wrap_content"
            android:layout_height="100dp"
            android:layout_row="0"
            android:layout_column="0"
            android:layout_margin="3dp"
            android:backgroundTint="#2196F3"
            android:text="CA"
            android:textSize="24sp"
            android:onClick="borrarTodo" />

        <Button
            android:id="@+id/buttonC"
            android:layout_width="wrap_content"
            android:layout_height="100dp"
            android:layout_row="0"
            android:layout_column="1"
            android:layout_margin="3dp"
            android:backgroundTint="#2196F3"
            android:text="C"
            android:textSize="24sp"
            android:onClick="borrar" />

        <Button
            android:id="@+id/buttonPorcentaje"
            android:layout_width="wrap_content"
            android:layout_height="100dp"
            android:layout_row="0"
            android:layout_column="2"
            android:layout_margin="3dp"
            android:backgroundTint="#2196F3"
            android:text="%"
            android:textSize="24sp"
            android:onClick="presionarOperacion" />

        <Button
            android:id="@+id/buttonDivision"
            android:layout_width="wrap_content"
            android:layout_height="100dp"
            android:layout_row="0"
            android:layout_column="3"
            android:layout_margin="3dp"
            android:backgroundTint="#2196F3"
            android:text="÷"
            android:textSize="24sp"
            android:onClick="presionarOperacion" />

        <Button
            android:id="@+id/button7"
            android:layout_width="wrap_content"
            android:layout_height="100dp"
            android:layout_row="1"
            android:layout_column="0"
            android:layout_margin="3dp"
            android:backgroundTint="@color/white"
            android:text="7"
            android:textColor="#2196F3"
            android:textSize="24sp"
            android:onClick="presionarNumero"
            app:strokeColor="#2196F3"
            app:strokeWidth="2dp" />

        <Button
            android:id="@+id/button8"
            android:layout_width="wrap_content"
            android:layout_height="100dp"
            android:layout_row="1"
            android:layout_column="1"
            android:layout_margin="3dp"
            android:backgroundTint="@color/white"
            android:text="8"
            android:textColor="#2196F3"
            android:textSize="24sp"
            android:onClick="presionarNumero"
            app:strokeColor="#2196F3"
            app:strokeWidth="2dp" />

        <Button
            android:id="@+id/button9"
            android:layout_width="wrap_content"
            android:layout_height="100dp"
            android:layout_row="1"
            android:layout_column="2"
            android:layout_margin="3dp"
            android:backgroundTint="@color/white"
            android:text="9"
            android:textColor="#2196F3"
            android:textSize="24sp"
            android:onClick="presionarNumero"
            app:strokeColor="#2196F3"
            app:strokeWidth="2dp" />

        <Button
            android:id="@+id/buttonMultiplicacion"
            android:layout_width="wrap_content"
            android:layout_height="100dp"
            android:layout_row="1"
            android:layout_column="3"
            android:layout_margin="3dp"
            android:backgroundTint="#2196F3"
            android:text="X"
            android:textSize="24sp"
            android:onClick="presionarOperacion" />

        <Button
            android:id="@+id/button4"
            android:layout_width="wrap_content"
            android:layout_height="100dp"
            android:layout_row="2"
            android:layout_column="0"
            android:layout_margin="3dp"
            android:backgroundTint="@color/white"
            android:text="4"
            android:textColor="#2196F3"
            android:textSize="24sp"
            android:onClick="presionarNumero"
            app:strokeColor="#2196F3"
            app:strokeWidth="2dp" />

        <Button
            android:id="@+id/button5"
            android:layout_width="wrap_content"
            android:layout_height="100dp"
            android:layout_row="2"
            android:layout_column="1"
            android:layout_margin="3dp"
            android:backgroundTint="@color/white"
            android:text="5"
            android:textColor="#2196F3"
            android:textSize="24sp"
            android:onClick="presionarNumero"
            app:strokeColor="#2196F3"
            app:strokeWidth="2dp" />

        <Button
            android:id="@+id/button6"
            android:layout_width="wrap_content"
            android:layout_height="100dp"
            android:layout_row="2"
            android:layout_column="2"
            android:layout_margin="3dp"
            android:backgroundTint="@color/white"
            android:text="6"
            android:textColor="#2196F3"
            android:textSize="24sp"
            android:onClick="presionarNumero"
            app:strokeColor="#2196F3"
            app:strokeWidth="2dp" />

        <Button
            android:id="@+id/buttonResta"
            android:layout_width="wrap_content"
            android:layout_height="100dp"
            android:layout_row="2"
            android:layout_column="3"
            android:layout_margin="3dp"
            android:backgroundTint="#2196F3"
            android:text="−"
            android:textSize="24sp"
            android:onClick="presionarOperacion" />

        <Button
            android:id="@+id/button1"
            android:layout_width="wrap_content"
            android:layout_height="100dp"
            android:layout_row="3"
            android:layout_column="0"
            android:layout_margin="3dp"
            android:backgroundTint="@color/white"
            android:text="1"
            android:textColor="#2196F3"
            android:textSize="24sp"
            android:onClick="presionarNumero"
            app:strokeColor="#2196F3"
            app:strokeWidth="2dp" />

        <Button
            android:id="@+id/button2"
            android:layout_width="wrap_content"
            android:layout_height="100dp"
            android:layout_row="3"
            android:layout_column="1"
            android:layout_margin="3dp"
            android:backgroundTint="@color/white"
            android:text="2"
            android:textColor="#2196F3"
            android:textSize="24sp"
            android:onClick="presionarNumero"
            app:strokeColor="#2196F3"
            app:strokeWidth="2dp" />

        <Button
            android:id="@+id/button3"
            android:layout_width="wrap_content"
            android:layout_height="100dp"
            android:layout_row="3"
            android:layout_column="2"
            android:layout_margin="3dp"
            android:backgroundTint="@color/white"
            android:text="3"
            android:textColor="#2196F3"
            android:textSize="24sp"
            android:onClick="presionarNumero"
            app:strokeColor="#2196F3"
            app:strokeWidth="2dp" />

        <Button
            android:id="@+id/buttonSuma"
            android:layout_width="wrap_content"
            android:layout_height="100dp"
            android:layout_row="3"
            android:layout_column="3"
            android:layout_margin="3dp"
            android:backgroundTint="#2196F3"
            android:text="+"
            android:textSize="24sp"
            android:onClick="presionarOperacion" />

        <Button
            android:id="@+id/button0"
            android:layout_width="wrap_content"
            android:layout_height="100dp"
            android:layout_row="4"
            android:layout_column="0"
            android:layout_margin="3dp"
            android:backgroundTint="@color/white"
            android:text="0"
            android:textColor="#2196F3"
            android:textSize="24sp"
            android:onClick="presionarNumero"
            app:strokeColor="#2196F3"
            app:strokeWidth="2dp" />

        <Button
            android:id="@+id/buttonDecimal"
            android:layout_width="wrap_content"
            android:layout_height="100dp"
            android:layout_row="4"
            android:layout_column="1"
            android:layout_margin="3dp"
            android:backgroundTint="@color/white"
            android:text="."
            android:textColor="#2196F3"
            android:textSize="24sp"
            android:onClick="presionarNumero"
            app:strokeColor="#2196F3"
            app:strokeWidth="2dp" />

        <Button
            android:id="@+id/buttonIgual"
            android:layout_width="180dp"
            android:layout_height="100dp"
            android:layout_row="4"
            android:layout_column="2"
            android:layout_columnSpan="2"
            android:layout_margin="3dp"
            android:backgroundTint="#2196F3"
            android:text="="
            android:textSize="24sp"
            android:onClick="presionarIgual" />

    </GridLayout>
</LinearLayout>